{
  "FileSystem": {
    "AllowedBasePaths": [],
    "DenyFilePatterns": [ "*.key", "*.pfx", "*.p12", "*.pem", "*.cer", ".env", ".env.*", "*.secret", "appsettings*.json", "id_rsa", "id_ed25519", "*.kubeconfig" ],
    "FollowSymlinks": false,
    "AllowWrites": false,
    "EnabledTools": [],
    "MaxReadFileSizeBytes": 10485760,
    "MaxDirectoryListEntries": 500,
    "MaxSearchResults": 200,
    "TextEnabled": true,
    "PdfEnabled": true,
    "ImagesEnabled": true,
    "StandaloneApiKey": "",
    "Pdf": {
      "MaxPages": 100,
      "IncludeMetadata": true,
      "IncludePageNumbers": true
    },
    "Image": {
      "ExtractExif": true,
      "ComputeQualityMetrics": true,
      "ReturnBase64": false,
      "ReturnThumbnail": true,
      "ThumbnailMaxDimension": 256,
      "MaxImageFileSizeBytes": 20971520,
      "BlurThreshold": 100.0,
      "ExposureUnderThreshold": 50.0,
      "ExposureOverThreshold": 205.0,
      "ClassificationEnabled": false
    }
  },
  "Jwt": {
    "SigningKey": "",
    "Issuer": "diva-fs-mcp",
    "Audience": "diva-fs-mcp-clients",
    "TokenExpiryMinutes": 60
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
